/*
 * Storefront Template Renderer
 * Layout-level renderer, not just CSS theme overrides.
 */

.ltr-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 8% 8%, color-mix(in srgb, var(--lapakin-template-accent) 14%, transparent), transparent 18rem),
    var(--lapakin-template-bg);
  color: var(--lapakin-template-ink);
  padding: clamp(1rem, 3vw, 2rem);
}

.ltr-container {
  position: relative;
  z-index: 1;
  width: min(1120px, 100%);
  margin: 0 auto;
  display: grid;
  gap: clamp(1rem, 3vw, 2rem);
}

.ltr-background-orb {
  position: fixed;
  z-index: 0;
  border-radius: 999px;
  pointer-events: none;
  filter: blur(4px);
  opacity: 0.55;
}

.ltr-background-orb-one {
  width: 320px;
  height: 320px;
  right: -120px;
  top: 8%;
  background: color-mix(in srgb, var(--lapakin-template-accent) 20%, transparent);
}

.ltr-background-orb-two {
  width: 240px;
  height: 240px;
  left: -96px;
  bottom: 16%;
  background: color-mix(in srgb, var(--lapakin-template-accent) 14%, transparent);
}

.ltr-hero,
.ltr-section,
.ltr-story,
.ltr-promo,
.ltr-contact {
  border: 1px solid color-mix(in srgb, var(--lapakin-template-accent) 18%, transparent);
  background: color-mix(in srgb, var(--lapakin-template-surface) 94%, transparent);
  box-shadow: 0 22px 70px rgba(15, 23, 42, 0.08);
  border-radius: 2rem;
}

.ltr-hero {
  min-height: clamp(420px, 55vh, 640px);
  display: grid;
  grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
  align-items: center;
  gap: clamp(1.5rem, 4vw, 4rem);
  padding: clamp(1.5rem, 5vw, 4rem);
  overflow: hidden;
  position: relative;
}

.ltr-hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    linear-gradient(135deg, color-mix(in srgb, var(--lapakin-template-accent) 12%, transparent), transparent 46%),
    radial-gradient(circle at 86% 14%, color-mix(in srgb, var(--lapakin-template-accent) 22%, transparent), transparent 16rem);
  pointer-events: none;
}

.ltr-hero-content,
.ltr-hero-visual {
  position: relative;
  z-index: 1;
}

.ltr-eyebrow,
.ltr-section-heading span,
.ltr-story span,
.ltr-promo span,
.ltr-contact span,
.ltr-product-meta span {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  border-radius: 999px;
  padding: 0.35rem 0.75rem;
  background: color-mix(in srgb, var(--lapakin-template-accent) 14%, white);
  color: var(--lapakin-template-accent);
  font-size: 0.74rem;
  font-weight: 900;
  letter-spacing: 0.04em;
  text-transform: uppercase;
}

.ltr-hero h1 {
  margin-top: 1rem;
  font-size: clamp(2.3rem, 7vw, 5.4rem);
  line-height: 0.95;
  font-weight: 950;
  letter-spacing: -0.07em;
  color: var(--lapakin-template-ink);
}

.ltr-hero h1 span {
  color: var(--lapakin-template-accent);
}

.ltr-hero p {
  margin-top: 1.1rem;
  max-width: 620px;
  color: var(--lapakin-template-muted);
  font-size: clamp(1rem, 2vw, 1.18rem);
  line-height: 1.75;
}

.ltr-hero-actions {
  margin-top: 1.6rem;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 0.8rem;
}

.ltr-primary-cta,
.ltr-contact a,
.ltr-promo a,
.ltr-product-footer a {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  background: var(--lapakin-template-accent);
  color: white;
  text-decoration: none;
  font-weight: 900;
  box-shadow: 0 14px 32px color-mix(in srgb, var(--lapakin-template-accent) 28%, transparent);
}

.ltr-primary-cta,
.ltr-contact a,
.ltr-promo a {
  padding: 0.85rem 1.2rem;
}

.ltr-template-pill {
  border-radius: 999px;
  padding: 0.7rem 1rem;
  border: 1px solid color-mix(in srgb, var(--lapakin-template-accent) 20%, transparent);
  color: var(--lapakin-template-muted);
  font-weight: 800;
  font-size: 0.86rem;
}

.ltr-hero-stats {
  margin-top: 2rem;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 0.8rem;
  max-width: 560px;
}

.ltr-hero-stats div {
  border-radius: 1.25rem;
  background: color-mix(in srgb, var(--lapakin-template-surface) 80%, transparent);
  border: 1px solid color-mix(in srgb, var(--lapakin-template-accent) 14%, transparent);
  padding: 1rem;
}

.ltr-hero-stats strong,
.ltr-hero-stats span {
  display: block;
}

.ltr-hero-stats strong {
  font-size: 1.25rem;
  font-weight: 950;
}

.ltr-hero-stats span {
  margin-top: 0.2rem;
  color: var(--lapakin-template-muted);
  font-size: 0.78rem;
  font-weight: 800;
}

.ltr-hero-visual {
  min-height: 360px;
  display: grid;
  place-items: center;
}

.ltr-hero-logo,
.ltr-hero-product {
  width: min(100%, 360px);
  aspect-ratio: 1 / 1;
  object-fit: cover;
  border-radius: 2.2rem;
  box-shadow: 0 30px 80px rgba(15, 23, 42, 0.2);
  border: 10px solid color-mix(in srgb, var(--lapakin-template-surface) 78%, transparent);
}

.ltr-hero-card {
  margin-top: -3.5rem;
  margin-left: auto;
  width: min(280px, 90%);
  border-radius: 1.5rem;
  background: color-mix(in srgb, var(--lapakin-template-surface) 92%, transparent);
  border: 1px solid color-mix(in srgb, var(--lapakin-template-accent) 18%, transparent);
  padding: 1rem;
  box-shadow: 0 18px 50px rgba(15, 23, 42, 0.14);
}

.ltr-hero-card span,
.ltr-hero-card strong,
.ltr-hero-card small {
  display: block;
}

.ltr-hero-card span {
  color: var(--lapakin-template-accent);
  font-size: 0.75rem;
  font-weight: 900;
  text-transform: uppercase;
}

.ltr-hero-card strong {
  margin-top: 0.25rem;
  font-size: 1rem;
  color: var(--lapakin-template-ink);
}

.ltr-hero-card small {
  margin-top: 0.25rem;
  color: var(--lapakin-template-muted);
  font-weight: 800;
}

.ltr-section,
.ltr-story,
.ltr-promo,
.ltr-contact {
  padding: clamp(1.25rem, 4vw, 2.25rem);
}

.ltr-section-heading {
  max-width: 720px;
  margin-bottom: 1.25rem;
}

.ltr-section-heading h2,
.ltr-story h2,
.ltr-promo h2,
.ltr-contact h2 {
  margin-top: 0.7rem;
  color: var(--lapakin-template-ink);
  font-size: clamp(1.55rem, 4vw, 2.6rem);
  line-height: 1.05;
  font-weight: 950;
  letter-spacing: -0.045em;
}

.ltr-section-heading p,
.ltr-story p,
.ltr-contact p {
  margin-top: 0.65rem;
  color: var(--lapakin-template-muted);
  line-height: 1.75;
}

.ltr-category-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 0.65rem;
}

.ltr-chip {
  border-radius: 999px;
  padding: 0.7rem 1rem;
  background: color-mix(in srgb, var(--lapakin-template-accent) 10%, white);
  color: var(--lapakin-template-ink);
  font-weight: 900;
  border: 1px solid color-mix(in srgb, var(--lapakin-template-accent) 14%, transparent);
}

.ltr-products-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(min(100%, 230px), 1fr));
  gap: 1rem;
}

.ltr-product-card {
  overflow: hidden;
  border-radius: 1.5rem;
  background: var(--lapakin-template-surface);
  border: 1px solid color-mix(in srgb, var(--lapakin-template-accent) 16%, transparent);
  box-shadow: 0 18px 48px rgba(15, 23, 42, 0.08);
  color: var(--lapakin-template-ink);
}

.ltr-product-image {
  width: 100%;
  aspect-ratio: 1 / 1;
  display: block;
  object-fit: cover;
  background: color-mix(in srgb, var(--lapakin-template-accent) 10%, white);
}

.ltr-product-image-placeholder {
  display: grid;
  place-items: center;
  color: var(--lapakin-template-accent);
  font-size: 2rem;
  font-weight: 950;
}

.ltr-product-body {
  padding: 1rem;
}

.ltr-product-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.35rem;
}

.ltr-product-meta span {
  padding: 0.25rem 0.55rem;
  font-size: 0.63rem;
}

.ltr-product-card h3 {
  margin-top: 0.7rem;
  color: var(--lapakin-template-ink);
  font-size: 1.08rem;
  font-weight: 950;
  letter-spacing: -0.025em;
}

.ltr-product-card p {
  margin-top: 0.45rem;
  color: var(--lapakin-template-muted);
  line-height: 1.55;
  font-size: 0.9rem;
}

.ltr-product-footer {
  margin-top: 1rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 0.75rem;
}

.ltr-product-footer strong {
  color: var(--lapakin-template-ink);
  font-size: 0.95rem;
}

.ltr-product-footer a {
  padding: 0.55rem 0.78rem;
  font-size: 0.8rem;
  white-space: nowrap;
}

.ltr-promo,
.ltr-contact {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.25rem;
}

.ltr-promo h2,
.ltr-contact h2 {
  max-width: 760px;
}

.ltr-story {
  min-height: 260px;
  display: grid;
  align-content: center;
}

.ltr-story p {
  max-width: 860px;
  font-size: 1.05rem;
}

.ltr-benefits,
.ltr-faq {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(min(100%, 220px), 1fr));
  gap: 0.9rem;
}

.ltr-benefits div,
.ltr-faq div {
  border-radius: 1.25rem;
  background: color-mix(in srgb, var(--lapakin-template-accent) 8%, var(--lapakin-template-surface));
  border: 1px solid color-mix(in srgb, var(--lapakin-template-accent) 14%, transparent);
  padding: 1rem;
}

.ltr-benefits strong,
.ltr-faq strong {
  color: var(--lapakin-template-ink);
}

.ltr-benefits p,
.ltr-faq p {
  margin-top: 0.4rem;
  color: var(--lapakin-template-muted);
  line-height: 1.6;
  font-size: 0.9rem;
}

/* Food templates become menu-like */
.ltr-mode-food_menu .ltr-products-grid {
  grid-template-columns: 1fr;
}

.ltr-mode-food_menu .ltr-product-card {
  display: grid;
  grid-template-columns: minmax(92px, 150px) 1fr;
}

.ltr-mode-food_menu .ltr-product-image {
  height: 100%;
  min-height: 130px;
}

.ltr-mode-food_menu .ltr-product-body {
  display: grid;
  align-content: center;
}

/* Service templates become service landing cards */
.ltr-mode-services .ltr-products-grid {
  grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
}

.ltr-mode-services .ltr-product-image {
  aspect-ratio: 16 / 9;
}

.ltr-mode-services .ltr-product-card {
  border-style: dashed;
}

/* Compact templates */
.ltr-density-tight {
  padding: 0.75rem;
}

.ltr-density-tight .ltr-container {
  gap: 0.8rem;
}

.ltr-density-tight .ltr-hero {
  min-height: auto;
  grid-template-columns: 1fr;
  padding: 1.25rem;
}

.ltr-density-tight .ltr-hero-visual {
  min-height: 0;
  display: none;
}

.ltr-density-tight .ltr-section,
.ltr-density-tight .ltr-story,
.ltr-density-tight .ltr-promo,
.ltr-density-tight .ltr-contact {
  padding: 1rem;
  border-radius: 1rem;
}

.ltr-density-tight .ltr-products-grid {
  gap: 0.65rem;
}

.ltr-density-tight .ltr-product-card {
  display: grid;
  grid-template-columns: 80px 1fr;
  border-radius: 1rem;
}

.ltr-density-tight .ltr-product-image {
  height: 100%;
  min-height: 92px;
}

.ltr-density-tight .ltr-product-body {
  padding: 0.75rem;
}

/* Premium templates */
.ltr-template-catalog_premium,
.ltr-template-food_premium,
.ltr-template-services_premium {
  background:
    radial-gradient(circle at top, rgba(217, 119, 6, 0.26), transparent 22rem),
    radial-gradient(circle at bottom right, rgba(120, 53, 15, 0.24), transparent 30rem),
    #0c0a09;
}

.ltr-template-catalog_premium .ltr-hero,
.ltr-template-food_premium .ltr-hero,
.ltr-template-services_premium .ltr-hero,
.ltr-template-catalog_premium .ltr-section,
.ltr-template-food_premium .ltr-section,
.ltr-template-services_premium .ltr-section,
.ltr-template-catalog_premium .ltr-story,
.ltr-template-food_premium .ltr-story,
.ltr-template-services_premium .ltr-story,
.ltr-template-catalog_premium .ltr-contact,
.ltr-template-food_premium .ltr-contact,
.ltr-template-services_premium .ltr-contact,
.ltr-template-catalog_premium .ltr-product-card,
.ltr-template-food_premium .ltr-product-card,
.ltr-template-services_premium .ltr-product-card {
  background: rgba(28, 25, 23, 0.92);
  border-color: rgba(245, 158, 11, 0.28);
  color: #fafaf9;
}

.ltr-template-catalog_premium .ltr-hero h1,
.ltr-template-food_premium .ltr-hero h1,
.ltr-template-services_premium .ltr-hero h1,
.ltr-template-catalog_premium h2,
.ltr-template-food_premium h2,
.ltr-template-services_premium h2,
.ltr-template-catalog_premium h3,
.ltr-template-food_premium h3,
.ltr-template-services_premium h3,
.ltr-template-catalog_premium strong,
.ltr-template-food_premium strong,
.ltr-template-services_premium strong {
  color: #fafaf9;
}

/* Playful templates */
.ltr-template-catalog_playful,
.ltr-template-food_playful,
.ltr-template-services_playful {
  background:
    radial-gradient(circle at 12% 12%, rgba(251, 146, 60, 0.28), transparent 12rem),
    radial-gradient(circle at 82% 8%, rgba(253, 224, 71, 0.35), transparent 10rem),
    linear-gradient(135deg, var(--lapakin-template-bg), #fef3c7);
}

.ltr-template-catalog_playful .ltr-hero,
.ltr-template-food_playful .ltr-hero,
.ltr-template-services_playful .ltr-hero,
.ltr-template-catalog_playful .ltr-section,
.ltr-template-food_playful .ltr-section,
.ltr-template-services_playful .ltr-section,
.ltr-template-catalog_playful .ltr-product-card,
.ltr-template-food_playful .ltr-product-card,
.ltr-template-services_playful .ltr-product-card {
  border-radius: 2rem;
}

/* Modern templates */
.ltr-template-catalog_modern .ltr-hero,
.ltr-template-food_modern .ltr-hero,
.ltr-template-services_modern .ltr-hero {
  background:
    linear-gradient(135deg, color-mix(in srgb, var(--lapakin-template-accent) 12%, white), white);
}

/* Hero variants */
.ltr-hero-luxury_banner,
.ltr-hero-chef_story_banner,
.ltr-hero-luxury_service_banner {
  grid-template-columns: 1fr;
  min-height: 560px;
  text-align: center;
}

.ltr-hero-luxury_banner .ltr-hero-content,
.ltr-hero-chef_story_banner .ltr-hero-content,
.ltr-hero-luxury_service_banner .ltr-hero-content {
  margin: 0 auto;
}

.ltr-hero-luxury_banner .ltr-hero-actions,
.ltr-hero-chef_story_banner .ltr-hero-actions,
.ltr-hero-luxury_service_banner .ltr-hero-actions,
.ltr-hero-luxury_banner .ltr-hero-stats,
.ltr-hero-chef_story_banner .ltr-hero-stats,
.ltr-hero-luxury_service_banner .ltr-hero-stats {
  margin-left: auto;
  margin-right: auto;
}

.ltr-hero-minimal_header,
.ltr-hero-minimal_food_header,
.ltr-hero-minimal_service_header {
  min-height: auto;
  grid-template-columns: 1fr;
}

.ltr-hero-minimal_header .ltr-hero-visual,
.ltr-hero-minimal_food_header .ltr-hero-visual,
.ltr-hero-minimal_service_header .ltr-hero-visual {
  display: none;
}

@media (max-width: 760px) {
  .ltr-page {
    padding: 0.75rem;
  }

  .ltr-hero {
    grid-template-columns: 1fr;
    min-height: auto;
    padding: 1.2rem;
  }

  .ltr-hero h1 {
    font-size: clamp(2rem, 14vw, 3.5rem);
  }

  .ltr-hero-visual {
    min-height: auto;
  }

  .ltr-hero-logo,
  .ltr-hero-product {
    width: min(100%, 280px);
  }

  .ltr-hero-card {
    margin: -2rem auto 0;
  }

  .ltr-hero-stats {
    grid-template-columns: 1fr;
  }

  .ltr-promo,
  .ltr-contact {
    align-items: flex-start;
    flex-direction: column;
  }

  .ltr-mode-food_menu .ltr-product-card,
  .ltr-density-tight .ltr-product-card {
    grid-template-columns: 86px 1fr;
  }

  .ltr-product-footer {
    align-items: flex-start;
    flex-direction: column;
  }

  .ltr-product-footer a {
    width: 100%;
  }
}


/* About + social links */
.ltr-social-links {
  margin-top: 1rem;
  display: flex;
  flex-wrap: wrap;
  gap: 0.6rem;
}

.ltr-social-link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 999px;
  padding: 0.62rem 0.92rem;
  border: 1px solid color-mix(in srgb, var(--lapakin-template-accent) 20%, transparent);
  background: color-mix(in srgb, var(--lapakin-template-accent) 8%, var(--lapakin-template-surface));
  color: var(--lapakin-template-ink);
  font-size: 0.84rem;
  font-weight: 900;
  text-decoration: none;
}

.ltr-social-link:hover {
  transform: translateY(-1px);
  box-shadow: 0 12px 24px color-mix(in srgb, var(--lapakin-template-accent) 18%, transparent);
}

.ltr-social-instagram::before {
  content: "IG";
  margin-right: 0.45rem;
  color: var(--lapakin-template-accent);
  font-size: 0.72rem;
  font-weight: 950;
}

.ltr-social-tiktok::before {
  content: "TT";
  margin-right: 0.45rem;
  color: var(--lapakin-template-accent);
  font-size: 0.72rem;
  font-weight: 950;
}

.ltr-template-catalog_premium .ltr-social-link,
.ltr-template-food_premium .ltr-social-link,
.ltr-template-services_premium .ltr-social-link {
  background: rgba(245, 158, 11, 0.12);
  color: #fafaf9;
  border-color: rgba(245, 158, 11, 0.32);
}


/* Mobile storefront renderer polish */
.ltr-mobile-sticky-order {
  display: none;
}

@media (max-width: 760px) {
  .ltr-page {
    padding: 0.7rem;
    padding-bottom: 5.5rem;
  }

  .ltr-container {
    gap: 0.85rem;
  }

  .ltr-hero,
  .ltr-section,
  .ltr-story,
  .ltr-promo,
  .ltr-contact {
    border-radius: 1.4rem;
  }

  .ltr-hero {
    min-height: auto;
    padding: 1rem;
    gap: 1rem;
  }

  .ltr-hero::before {
    opacity: 0.78;
  }

  .ltr-eyebrow,
  .ltr-section-heading span,
  .ltr-story span,
  .ltr-promo span,
  .ltr-contact span,
  .ltr-product-meta span {
    font-size: 0.66rem;
    padding: 0.28rem 0.58rem;
  }

  .ltr-hero h1 {
    margin-top: 0.75rem;
    font-size: clamp(1.95rem, 12vw, 3.2rem);
    letter-spacing: -0.055em;
    line-height: 0.98;
  }

  .ltr-hero p {
    margin-top: 0.8rem;
    font-size: 0.95rem;
    line-height: 1.62;
  }

  .ltr-hero-actions {
    margin-top: 1rem;
  }

  .ltr-primary-cta,
  .ltr-contact a,
  .ltr-promo a {
    width: 100%;
    padding: 0.82rem 1rem;
  }

  .ltr-template-pill {
    display: none;
  }

  .ltr-hero-stats {
    margin-top: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.45rem;
  }

  .ltr-hero-stats div {
    padding: 0.7rem 0.5rem;
    border-radius: 1rem;
  }

  .ltr-hero-stats strong {
    font-size: 1rem;
  }

  .ltr-hero-stats span {
    font-size: 0.65rem;
  }

  .ltr-hero-visual {
    min-height: auto;
  }

  .ltr-hero-logo,
  .ltr-hero-product {
    width: min(100%, 230px);
    border-width: 6px;
    border-radius: 1.5rem;
  }

  .ltr-hero-card {
    width: min(260px, 94%);
    margin-top: -1.25rem;
    border-radius: 1.15rem;
    padding: 0.8rem;
  }

  .ltr-section,
  .ltr-story,
  .ltr-promo,
  .ltr-contact {
    padding: 1rem;
  }

  .ltr-section-heading {
    margin-bottom: 0.85rem;
  }

  .ltr-section-heading h2,
  .ltr-story h2,
  .ltr-promo h2,
  .ltr-contact h2 {
    font-size: clamp(1.35rem, 8vw, 2rem);
    letter-spacing: -0.035em;
  }

  .ltr-section-heading p,
  .ltr-story p,
  .ltr-contact p {
    font-size: 0.93rem;
    line-height: 1.62;
  }

  .ltr-category-chips {
    gap: 0.45rem;
    overflow-x: auto;
    flex-wrap: nowrap;
    padding-bottom: 0.15rem;
    scrollbar-width: none;
  }

  .ltr-category-chips::-webkit-scrollbar {
    display: none;
  }

  .ltr-chip {
    flex: 0 0 auto;
    padding: 0.55rem 0.8rem;
    font-size: 0.82rem;
  }

  .ltr-products-grid {
    grid-template-columns: 1fr;
    gap: 0.72rem;
  }

  .ltr-product-card {
    border-radius: 1.15rem;
  }

  .ltr-product-body {
    padding: 0.82rem;
  }

  .ltr-product-card h3 {
    margin-top: 0.55rem;
    font-size: 0.98rem;
  }

  .ltr-product-card p {
    font-size: 0.84rem;
    line-height: 1.48;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .ltr-product-footer {
    margin-top: 0.75rem;
    flex-direction: row;
    align-items: center;
  }

  .ltr-product-footer strong {
    font-size: 0.86rem;
  }

  .ltr-product-footer a {
    width: auto;
    min-width: 72px;
    padding: 0.5rem 0.7rem;
  }

  .ltr-mode-food_menu .ltr-product-card,
  .ltr-density-tight .ltr-product-card {
    grid-template-columns: 86px 1fr;
  }

  .ltr-mode-food_menu .ltr-product-image,
  .ltr-density-tight .ltr-product-image {
    min-height: 100%;
    height: 100%;
    aspect-ratio: auto;
  }

  .ltr-mode-food_menu .ltr-product-body,
  .ltr-density-tight .ltr-product-body {
    min-width: 0;
  }

  .ltr-mode-food_menu .ltr-product-card h3,
  .ltr-density-tight .ltr-product-card h3 {
    font-size: 0.95rem;
  }

  .ltr-mode-food_menu .ltr-product-card p,
  .ltr-density-tight .ltr-product-card p {
    font-size: 0.78rem;
    -webkit-line-clamp: 1;
  }

  .ltr-mode-services .ltr-product-image {
    aspect-ratio: 16 / 9;
  }

  .ltr-promo,
  .ltr-contact {
    gap: 0.8rem;
  }

  .ltr-social-links {
    gap: 0.45rem;
  }

  .ltr-social-link {
    flex: 1 1 auto;
    min-width: 120px;
    padding: 0.58rem 0.7rem;
    font-size: 0.8rem;
  }

  .ltr-benefits,
  .ltr-faq {
    grid-template-columns: 1fr;
    gap: 0.65rem;
  }

  .ltr-benefits div,
  .ltr-faq div {
    border-radius: 1rem;
    padding: 0.85rem;
  }

  .ltr-story {
    min-height: auto;
  }

  .ltr-mobile-sticky-order {
    position: fixed;
    left: 0.75rem;
    right: 0.75rem;
    bottom: 0.75rem;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    border: 1px solid color-mix(in srgb, var(--lapakin-template-accent) 28%, transparent);
    border-radius: 1.2rem;
    background: color-mix(in srgb, var(--lapakin-template-surface) 92%, transparent);
    color: var(--lapakin-template-ink);
    box-shadow: 0 18px 48px rgba(15, 23, 42, 0.22);
    padding: 0.72rem;
    backdrop-filter: blur(16px);
  }

  .ltr-mobile-sticky-order div {
    min-width: 0;
  }

  .ltr-mobile-sticky-order span,
  .ltr-mobile-sticky-order strong {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .ltr-mobile-sticky-order span {
    color: var(--lapakin-template-muted);
    font-size: 0.72rem;
    font-weight: 800;
  }

  .ltr-mobile-sticky-order strong {
    color: var(--lapakin-template-ink);
    font-size: 0.88rem;
    font-weight: 950;
  }

  .ltr-mobile-sticky-order a {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.95rem;
    background: var(--lapakin-template-accent);
    color: #fff;
    padding: 0.62rem 0.9rem;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 950;
  }

  .ltr-template-catalog_premium .ltr-mobile-sticky-order,
  .ltr-template-food_premium .ltr-mobile-sticky-order,
  .ltr-template-services_premium .ltr-mobile-sticky-order {
    background: rgba(28, 25, 23, 0.92);
    border-color: rgba(245, 158, 11, 0.35);
  }

  .ltr-template-catalog_premium .ltr-mobile-sticky-order a,
  .ltr-template-food_premium .ltr-mobile-sticky-order a,
  .ltr-template-services_premium .ltr-mobile-sticky-order a {
    color: #111827;
  }
}

@media (max-width: 380px) {
  .ltr-page {
    padding: 0.55rem;
    padding-bottom: 5.25rem;
  }

  .ltr-hero,
  .ltr-section,
  .ltr-story,
  .ltr-promo,
  .ltr-contact {
    padding: 0.82rem;
  }

  .ltr-hero h1 {
    font-size: clamp(1.75rem, 11vw, 2.8rem);
  }

  .ltr-hero-stats {
    grid-template-columns: 1fr;
  }

  .ltr-mode-food_menu .ltr-product-card,
  .ltr-density-tight .ltr-product-card {
    grid-template-columns: 76px 1fr;
  }

  .ltr-product-footer {
    align-items: flex-start;
    flex-direction: column;
  }

  .ltr-product-footer a {
    width: 100%;
  }

  .ltr-mobile-sticky-order {
    left: 0.55rem;
    right: 0.55rem;
    bottom: 0.55rem;
  }
}
