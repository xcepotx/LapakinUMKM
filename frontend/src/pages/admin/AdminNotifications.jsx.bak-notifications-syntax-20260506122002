import { useEffect, useMemo, useState } from "react";
import AdminLayout from "@/components/AdminLayout";
import api, { formatApiError } from "@/lib/api";
import {
  Bell,
  CheckCircle2,
  Clipboard,
  CreditCard,
  RefreshCw,
  Search,
  Store,
  Timer,
  CalendarClock,
} from "lucide-react";
import { toast } from "sonner";

const STATUS_FILTERS = [
  { value: "open", label: "Open" },
  { value: "snoozed", label: "Snoozed" },
  { value: "done", label: "Done" },
  { value: "all", label: "Semua" },
];

const TYPE_FILTERS = [
  { value: "all", label: "Semua tipe" },
  { value: "trial", label: "Trial" },
  { value: "payment", label: "Payment" },
  { value: "onboarding", label: "Onboarding" },
  { value: "store_health", label: "Store Health" },
];

function formatDate(value, withTime = true) {
  if (!value) return "-";
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return String(value);
  return date.toLocaleString("id-ID", {
    day: "2-digit",
    month: "short",
    year: "numeric",
    ...(withTime ? { hour: "2-digit", minute: "2-digit" } : {}),
  });
}

function typeIcon(type) {
  if (type === "trial") return Timer;
  if (type === "payment") return CreditCard;
  if (type === "onboarding") return CalendarClock;
  if (type === "store_health") return Store;
  return Bell;
}

function priorityClass(priority) {
  if (priority === "high") return "border-red-200 bg-red-50 text-red-700";
  if (priority === "medium") return "border-amber-200 bg-amber-50 text-amber-700";
  return "border-brand-line bg-brand-off text-brand-ink";
}

function statusClass(status) {
  if (status === "done") return "border-emerald-200 bg-emerald-50 text-emerald-700";
  if (status === "snoozed") return "border-blue-200 bg-blue-50 text-blue-700";
  return "border-amber-200 bg-amber-50 text-amber-700";
}

async function copyText(text) {
  if (navigator?.clipboard?.writeText) {
    await navigator.clipboard.writeText(text || "");
    return;
  }
  const el = document.createElement("textarea");
  el.value = text || "";
  document.body.appendChild(el);
  el.select();
  document.execCommand("copy");
  document.body.removeChild(el);
}

function NotificationCard({ item, actingId, onDone, onSnooze, onCopy }) {
  const Icon = typeIcon(item.type);
  return (
    <div className="rounded-3xl border border-brand-line bg-white p-4 shadow-sm">
      <div className="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
        <div className="min-w-0 flex-1">
          <div className="flex flex-wrap items-center gap-2">
            <div className="rounded-2xl bg-brand-off p-2 text-brand">
              <Icon className="h-4 w-4" />
            </div>
            <h3 className="font-extrabold text-brand-ink">{item.title || "-"}</h3>
            <span className={`rounded-full border px-2.5 py-1 text-[11px] font-extrabold uppercase ${priorityClass(item.priority)}`}>
              {item.priority || "normal"}
            </span>
            <span className={`rounded-full border px-2.5 py-1 text-[11px] font-extrabold uppercase ${statusClass(item.status)}`}>
              {item.status || "open"}
            </span>
          </div>

          <p className="mt-2 text-sm text-brand-mute">{item.message || "-"}</p>

          <div className="mt-3 grid gap-3 text-xs text-brand-mute md:grid-cols-3">
            <div className="rounded-2xl bg-brand-off/60 p-3">
              <div className="font-extrabold text-brand-ink">Target</div>
              <div>{item.target_label || "-"}</div>
              <div>{item.target_email || "-"}</div>
            </div>
            <div className="rounded-2xl bg-brand-off/60 p-3">
              <div className="font-extrabold text-brand-ink">Deadline</div>
              <div>Due: {formatDate(item.due_at)}</div>
              <div>Snooze sampai: {formatDate(item.snoozed_until)}</div>
            </div>
            <div className="rounded-2xl bg-brand-off/60 p-3">
              <div className="font-extrabold text-brand-ink">Sumber</div>
              <div>{item.source || "-"}</div>
              <div>Dibuat: {formatDate(item.created_at)}</div>
            </div>
          </div>

          <details className="mt-3">
            <summary className="cursor-pointer text-xs font-extrabold text-brand hover:underline">
              Template follow-up
            </summary>
            <pre className="mt-2 whitespace-pre-wrap rounded-2xl bg-brand-off/70 p-3 text-xs text-brand-ink">
              {item.follow_up_message || "-"}
            </pre>
          </details>
        </div>

        <div className="grid min-w-[180px] gap-2">
          <button
            type="button"
            onClick={() => onCopy(item)}
            className="inline-flex items-center justify-center gap-1 rounded-xl border border-brand-line bg-white px-3 py-2 text-xs font-extrabold text-brand-ink hover:bg-brand-off"
          >
            <Clipboard className="h-3.5 w-3.5" />
            Copy WA Follow-up
          </button>
          <button
            type="button"
            onClick={() => onSnooze(item, 3)}
            disabled={actingId === `${item.notification_id}:snooze:3`}
            className="rounded-xl border border-brand-line bg-white px-3 py-2 text-xs font-extrabold text-brand-ink hover:bg-brand-off disabled:opacity-60"
          >
            Snooze 3 hari
          </button>
          <button
            type="button"
            onClick={() => onSnooze(item, 7)}
            disabled={actingId === `${item.notification_id}:snooze:7`}
            className="rounded-xl border border-brand-line bg-white px-3 py-2 text-xs font-extrabold text-brand-ink hover:bg-brand-off disabled:opacity-60"
          >
            Snooze 7 hari
          </button>
          <button
            type="button"
            onClick={() => onDone(item)}
            disabled={actingId === `${item.notification_id}:done`}
            className="inline-flex items-center justify-center gap-1 rounded-xl bg-brand px-3 py-2 text-xs font-extrabold text-white disabled:opacity-60"
          >
            <CheckCircle2 className="h-3.5 w-3.5" />
            Mark Done
          </button>
        </div>
      </div>
    </div>
  );
}

export default function AdminNotifications() {
  const [items, setItems] = useState([]);
  const [summary, setSummary] = useState({});
  const [status, setStatus] = useState("open");
  const [type, setType] = useState("all");
  const [q, setQ] = useState("");
  const [search, setSearch] = useState("");
  const [loading, setLoading] = useState(true);
  const [actingId, setActingId] = useState("");

  const load = async (nextStatus = status, nextType = type, nextQ = q) => {
    setLoading(true);
    try {
      const { data } = await api.get("/admin/notifications", {
        params: { status: nextStatus, type: nextType, q: nextQ, limit: 100 },
      });
      setItems(Array.isArray(data?.items) ? data.items : []);
      setSummary(data?.summary || {});
    } catch (err) {
      toast.error(formatApiError(err?.response?.data?.detail) || "Gagal memuat notifications");
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    load("open", "all", "");
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, []);

  const selectedStatusLabel = useMemo(
    () => STATUS_FILTERS.find((item) => item.value === status)?.label || "Open",
    [status]
  );
  const selectedTypeLabel = useMemo(
    () => TYPE_FILTERS.find((item) => item.value === type)?.label || "Semua tipe",
    [type]
  );

  const submitSearch = (event) => {
    event.preventDefault();
    setQ(search);
    load(status, type, search);
  };

  const changeStatus = (value) => {
    setStatus(value);
    load(value, type, q);
  };

  const changeType = (value) => {
    setType(value);
    load(status, value, q);
  };

  const markDone = async (item) => {
    const note = window.prompt(`Catatan selesai untuk ${item.title}:`, "Sudah difollow-up admin");
    if (note === null) return;

    setActingId(`${item.notification_id}:done`);
    try {
      await api.post(`/admin/notifications/${encodeURIComponent(item.notification_id)}/done`, { note });
      toast.success("Reminder ditandai done");
      await load(status, type, q);
    } catch (err) {
      toast.error(formatApiError(err?.response?.data?.detail) || "Gagal mark done");
    } finally {
      setActingId("");
    }
  };

  const snooze = async (item, days) => {
    const note = window.prompt(`Catatan snooze ${days} hari untuk ${item.title}:`, "Follow up nanti");
    if (note === null) return;

    setActingId(`${item.notification_id}:snooze:${days}`);
    try {
      await api.post(`/admin/notifications/${encodeURIComponent(item.notification_id)}/snooze`, { days, note });
      toast.success(`Reminder disnooze ${days} hari`);
      await load(status, type, q);
    } catch (err) {
      toast.error(formatApiError(err?.response?.data?.detail) || "Gagal snooze reminder");
    } finally {
      setActingId("");
    }
  };

  const copyFollowUp = async (item) => {
    try {
      await copyText(item.follow_up_message || item.message || "");
      toast.success("Template follow-up disalin");
    } catch {
      toast.error("Gagal copy template follow-up");
    }
  };

  return (
    <AdminLayout
      title="Notifications"
      subtitle="Reminder follow-up untuk trial, payment pending, onboarding, dan toko critical."
    >
      <div className="space-y-5" data-testid="admin-notifications-page">
        <div className="grid gap-3 md:grid-cols-4">
          <div className="rounded-3xl border border-brand-line bg-white p-4 shadow-sm">
            <div className="text-xs font-bold uppercase tracking-wide text-brand-mute">Open</div>
            <div className="mt-1 text-2xl font-extrabold text-brand-ink">{summary.open ?? 0}</div>
          </div>
          <div className="rounded-3xl border border-brand-line bg-white p-4 shadow-sm">
            <div className="text-xs font-bold uppercase tracking-wide text-brand-mute">High priority</div>
            <div className="mt-1 text-2xl font-extrabold text-red-700">{summary.high_priority ?? 0}</div>
          </div>
          <div className="rounded-3xl border border-brand-line bg-white p-4 shadow-sm">
            <div className="text-xs font-bold uppercase tracking-wide text-brand-mute">Snoozed</div>
            <div className="mt-1 text-2xl font-extrabold text-blue-700">{summary.snoozed ?? 0}</div>
          </div>
          <div className="rounded-3xl border border-brand-line bg-white p-4 shadow-sm">
            <div className="text-xs font-bold uppercase tracking-wide text-brand-mute">Done</div>
            <div className="mt-1 text-2xl font-extrabold text-emerald-700">{summary.done ?? 0}</div>
          </div>
        </div>

        <div className="rounded-3xl border border-brand-line bg-white p-5 shadow-sm">
          <div className="mb-4 flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
            <div>
              <div className="flex items-center gap-2">
                <Bell className="h-5 w-5 text-brand" />
                <h3 className="text-lg font-extrabold text-brand-ink">Follow-up reminders</h3>
              </div>
              <p className="mt-1 text-sm text-brand-mute">
                Status: {selectedStatusLabel} · Tipe: {selectedTypeLabel}
              </p>
            </div>

            <form onSubmit={submitSearch} className="flex gap-2">
              <div className="relative">
                <Search className="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-brand-mute" />
                <input
                  value={search}
                  onChange={(event) => setSearch(event.target.value)}
                  placeholder="Cari toko/user/payment..."
                  className="w-72 rounded-2xl border border-brand-line bg-white py-2 pl-9 pr-3 text-sm"
                />
              </div>
              <button type="submit" className="rounded-2xl bg-brand px-4 py-2 text-sm font-extrabold text-white">
                Cari
              </button>
              <button
                type="button"
                onClick={() => load(status, type, q)}
                className="rounded-2xl border border-brand-line bg-white px-3 py-2 text-brand-ink"
                title="Refresh"
              >
                <RefreshCw className="h-4 w-4" />
              </button>
            </form>
          </div>

          <div className="mb-3 flex flex-wrap gap-2">
            {STATUS_FILTERS.map((item) => (
              <button
                key={item.value}
                type="button"
                onClick={() => changeStatus(item.value)}
                className={`rounded-full border px-3 py-1.5 text-xs font-extrabold ${
                  status === item.value
                    ? "border-brand bg-brand text-white"
                    : "border-brand-line bg-white text-brand-ink hover:bg-brand-off"
                }`}
              >
                {item.label}
              </button>
            ))}
          </div>

          <div className="mb-4 flex flex-wrap gap-2">
            {TYPE_FILTERS.map((item) => (
              <button
                key={item.value}
                type="button"
                onClick={() => changeType(item.value)}
                className={`rounded-full border px-3 py-1.5 text-xs font-extrabold ${
                  type === item.value
                    ? "border-brand bg-brand text-white"
                    : "border-brand-line bg-white text-brand-ink hover:bg-brand-off"
                }`}
              >
                {item.label}
              </button>
            ))}
          </div>

          {loading ? (
            <div className="rounded-2xl bg-brand-off/60 px-4 py-8 text-sm text-brand-mute">Memuat notifications...</div>
          ) : items.length === 0 ? (
            <div className="rounded-2xl bg-brand-off/60 px-4 py-8 text-sm text-brand-mute">Tidak ada reminder pada filter ini.</div>
          ) : (
            <div className="space-y-3">
              {items.map((item) => (
                <NotificationCard
                  key={item.notification_id}
                  item={item}
                  actingId={actingId}
                  onDone={markDone}
                  onSnooze={snooze}
                  onCopy={copyFollowUp}
                />
              ))}
            </div>
          )}
        </div>
      </div>
    </AdminLayout>
  );
}
